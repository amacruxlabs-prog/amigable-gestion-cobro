rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
  
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() { 
      return request.auth != null && request.auth.token.email != null; 
    }
    
    function getUserEmail() {
      return request.auth.token.email;
    }

    function isInitialSuperadmin() {
      return isSignedIn() && getUserEmail() == "amacruxlabs@gmail.com";
    }

    function getRole() {
      return exists(/databases/$(database)/documents/roles/$(getUserEmail())) 
        ? get(/databases/$(database)/documents/roles/$(getUserEmail())).data.role 
        : null;
    }

    function isSuperadmin() {
      return isInitialSuperadmin() || (isSignedIn() && getRole() == 'superadmin');
    }

    function isAdmin() {
      return isSuperadmin() || (isSignedIn() && getRole() == 'admin');
    }
    
    function isVisor() {
      return isAdmin() || (isSignedIn() && getRole() == 'visor');
    }

    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-\\.\\@]+$'); 
    }
    
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isValidRole(data) {
      return data.keys().hasAll(['role', 'updatedAt']) 
      && data.role in ['superadmin', 'admin', 'visor']
      && data.updatedAt is string && data.updatedAt.size() <= 100
      && (data.get('assignedBy', '') is string)
      && (data.get('assignedBy', '').size() <= 200);
    }

    match /roles/{email} {
      allow read: if (isSignedIn() && getUserEmail() == email) || isSuperadmin();
      
      allow create: if isSuperadmin() 
        && isValidId(email)
        && isValidRole(incoming())
        && incoming().keys().size() <= 3;
        
      allow update: if isSuperadmin()
        && isValidId(email)
        && isValidRole(incoming())
        && incoming().diff(existing()).affectedKeys().hasOnly(['role', 'updatedAt', 'assignedBy']);
        
      allow delete: if isSuperadmin();
    }

    function isValidTransaction(data) {
      return data.keys().hasAll(['clientName', 'amount', 'status', 'date'])
        && data.clientName is string && data.clientName.size() <= 200
        && data.amount is number
        && data.status in ['Pagado', 'Cobrar']
        && data.date is string && data.date.size() <= 100
        && (data.get('phone', '') is string && data.get('phone', '').size() <= 50)
        && (data.get('cedula', '') is string && data.get('cedula', '').size() <= 50)
        && (data.get('location', '') is string && data.get('location', '').size() <= 500)
        && (data.get('notes', '') is string && data.get('notes', '').size() <= 1000)
        && (data.get('updatedBy', '') is string && data.get('updatedBy', '').size() <= 200)
        && (data.get('updatedByEmail', '') is string && data.get('updatedByEmail', '').size() <= 200)
        && (data.get('updatedAt', '') is string && data.get('updatedAt', '').size() <= 100)
        && (data.get('paidAmount', 0) is number)
        && (data.get('payments', []) is list)
        && (data.get('payments', []).size() <= 1000)
        // Allow map or null, using data.get fallback
        && (data.get('originalData', {}) is map || data.get('originalData', '') == '');
    }

    match /transactions/{transactionId} {
      allow read: if isVisor();
      
      allow create: if isAdmin()
        && isValidId(transactionId)
        && isValidTransaction(incoming());
        
      allow update: if isAdmin()
        && isValidId(transactionId)
        && isValidTransaction(incoming())
        && incoming().diff(existing()).affectedKeys().hasOnly([
          'clientName', 'amount', 'status', 'date', 'phone', 'cedula', 'location', 'paidAmount', 'payments', 'notes', 'updatedAt', 'updatedBy', 'updatedByEmail', 'originalData'
        ]);
        
      allow delete: if isSuperadmin();
    }

    match /settings/{docId} {
      allow read: if isVisor();
      allow write: if isAdmin();
    }

    function isValidAuditLog(data) {
      return data.keys().hasAll(['action', 'entityId', 'adminEmail', 'timestamp'])
        && data.action is string && data.action.size() <= 200
        && data.entityId is string && data.entityId.size() <= 128
        && data.adminEmail is string && data.adminEmail.size() <= 200
        && data.adminEmail == getUserEmail()
        && data.timestamp is string && data.timestamp.size() <= 100
        && (data.get('entityType', '') is string && data.get('entityType', '').size() <= 100)
        && (data.get('changes', '') is string && data.get('changes', '').size() <= 10000);
    }

    match /audit_logs/{logId} {
      allow read: if isSuperadmin();
      
      allow create: if isAdmin()
        && isValidId(logId)
        && isValidAuditLog(incoming());
        
      allow update, delete: if false;
    }
  }
}
